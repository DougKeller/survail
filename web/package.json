    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  }
