SESSION_SECRET=replace-with-a-long-random-value
AUTH_STRATEGY=discord
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
OPENAI_API_KEY=
OPENAI_DESCRIPTION_MODEL=gpt-4.1-mini
OPENAI_AGENT_MODEL=gpt-4.1-mini
OPENAI_IMPORT_MODEL=gpt-5.4
OPENAI_ROLE_EVALUATION_MODEL=gpt-5.4-mini
